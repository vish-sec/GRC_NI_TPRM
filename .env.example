# Copy to .env and fill in. The demo runs fully WITHOUT any of these (offline
# fallback uses the real assessor verdicts from the sample). PRODUCTION requires
# the secrets marked (required).

# --- AI (optional; demo works offline without a key) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Security (required in production) ---
# Signs session cookies. MUST be set to a strong, unique value in prod; the app
# refuses to start auth with the public dev default. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Encrypts provider API keys at rest. Falls back to SESSION_SECRET if unset.
#   openssl rand -hex 32
ENCRYPTION_KEY=

# Seeded demo accounts (root/dbs/apex/viewer, password "demo"). Auto-ON in dev,
# OFF in production. Set to "true" only to keep them for a hosted demo.
ALLOW_DEMO_ACCOUNTS=false

# Require an assessor-issued invite to onboard a vendor. Auto-ON in production,
# OFF in dev so the onboarding flow can be shown without one.
REQUIRE_INVITE=

# Allow LLM base URLs on private/loopback ranges (needed for local Ollama).
# Auto-ON in dev, OFF in prod (SSRF guard). Set "true" if you self-host an LLM
# on a private address in production.
ALLOW_PRIVATE_LLM_URL=

# Rate limiting for /api/login and /api/onboard (per IP per window).
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Audit log retention cap (file store; prod should forward to a WORM store/SIEM).
AUDIT_CAP=5000

# --- Database (docker-compose; Phase 2+ persistence) ---
POSTGRES_PASSWORD=tprm
DATABASE_URL=postgres://tprm:tprm@db:5432/tprm
